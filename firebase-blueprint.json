{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A literary project created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "genre": { "type": "string" },
        "synopsis": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["standard", "children", "ebook"] },
        "cover_url": { "type": "string" },
        "back_cover_url": { "type": "string" },
        "back_cover_text": { "type": "string" },
        "status": { "type": "string", "enum": ["writing", "reviewing", "finished", "published"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "language": { "type": "string" }
      },
      "required": ["title", "ownerId", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "An author or client managed by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "User": {
      "title": "User",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "basic", "premium"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of books."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    }
  }
}
